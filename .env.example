# Xeno CRM — Environment Variables Template
# Copy this file to .env and fill in real values. NEVER commit .env to git.

# Django
SECRET_KEY=change-this-to-a-random-50-char-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# Google Gemini AI (get key from https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your-google-api-key-here

# LLM Mode: False = Google Gemini (production), True = local Ollama (dev only)
USE_LOCAL_LLM=False

# Redis (Railway provides REDIS_URL automatically, or use Upstash for free tier)
REDIS_URL=redis://localhost:6379/0

# Internal service URLs (update when deploying to cloud)
CHANNEL_SERVICE_URL=http://localhost:5001
CRM_BASE_URL=http://localhost:8000

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# Local Ollama settings (only needed when USE_LOCAL_LLM=True)
LOCAL_LLM_PROVIDER=ollama
LOCAL_LLM_MODEL=qwen3:8b
LOCAL_LLM_API_BASE=http://localhost:11434
LOCAL_LLM_API_KEY=ollama
